    {
      "parameters": {
        "jsCode": "// Pisahkan data baru vs data yang diupdate untuk tr_ucapan\nconst staticData = $getWorkflowStaticData('global');\nconst lastUcapanId = staticData.lastUcapanId || 0;\nconst lastSyncTime = staticData.lastSyncTime || '2000-01-01 00:00:00';\n\nconst items = $input.all();\n\nif (items.length === 0) {\n  return [{ json: { isNew: false, isUpdate: false, isEmpty: true } }];\n}\n\nconst result = items.map(item => {\n  const row = item.json;\n  const ucapanId = parseInt(row.ucapanId) || 0;\n  const updatedAt = row.updated_at || null;\n\n  const isNew = ucapanId > lastUcapanId;\n  const isUpdate = !isNew && updatedAt && updatedAt > lastSyncTime;\n\n  return {\n    json: {\n      ...row,\n      _syncType: isNew ? 'new' : 'update',\n      isEmpty: false\n    }\n  };\n});\n\nreturn result;\n"
      },
