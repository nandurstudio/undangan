    {
      "parameters": {
        "jsCode": "// Ambil last sync time dari Static Data\nconst staticData = $getWorkflowStaticData('global');\n\n// Jika belum pernah sync, set ke 1 minggu lalu sebagai fallback\nif (!staticData.lastSyncTime) {\n  staticData.lastSyncTime = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 19).replace('T', ' ');\n}\n\nif (!staticData.lastTamuId) {\n  staticData.lastTamuId = 0;\n}\n\nif (!staticData.lastUcapanId) {\n  staticData.lastUcapanId = 0;\n}\n\nreturn [{\n  json: {\n    lastSyncTime: staticData.lastSyncTime,\n    lastTamuId: staticData.lastTamuId,\n    lastUcapanId: staticData.lastUcapanId,\n    currentTime: new Date().toISOString().slice(0, 19).replace('T', ' ')\n  }\n}];\n"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Get Last Sync State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM tr_tamu\nWHERE tamuId > {{ $json.lastTamuId }}\n   OR (updated_at IS NOT NULL AND updated_at > '{{ $json.lastSyncTime }}')\nORDER BY tamuId ASC\nLIMIT 500",
        "options": {}
      },
