      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM tr_ucapan\nWHERE ucapanId > {{ $json.lastUcapanId }}\n   OR (updated_at IS NOT NULL AND updated_at > '{{ $json.lastSyncTime }}')\nORDER BY ucapanId ASC\nLIMIT 500",
        "options": {}
      },
