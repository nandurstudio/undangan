      "parameters": {
        "jsCode": "// Simpan state terbaru setelah semua berhasil\nconst staticData = $getWorkflowStaticData('global');\n\n// Ambil semua items dari kedua branch\nconst allItems = $input.all();\n\nlet maxTamuId = staticData.lastTamuId || 0;\nlet maxUcapanId = staticData.lastUcapanId || 0;\n\nfor (const item of allItems) {\n  const row = item.json;\n  if (row.tamuId && parseInt(row.tamuId) > maxTamuId) {\n    maxTamuId = parseInt(row.tamuId);\n  }\n  if (row.ucapanId && parseInt(row.ucapanId) > maxUcapanId) {\n    maxUcapanId = parseInt(row.ucapanId);\n  }\n}\n\nstaticData.lastTamuId = maxTamuId;\nstaticData.lastUcapanId = maxUcapanId;\nstaticData.lastSyncTime = new Date().toISOString().slice(0, 19).replace('T', ' ');\n\nreturn [{ json: {\n  saved: true,\n  lastTamuId: staticData.lastTamuId,\n  lastUcapanId: staticData.lastUcapanId,\n  lastSyncTime: staticData.lastSyncTime\n}}];\n"
      },
